{
  "name": "@conference/finance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "emulator": "firebase emulators:start",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "seed": "npx tsx scripts/seed.ts",
    "seed:clear": "npx tsx scripts/clear.ts",
    "migrate:projects": "npx tsx scripts/migrate-projects.ts",
    "migrate:projects:emulator": "npx tsx scripts/migrate-projects.ts --emulator",
    "deploy": "pnpm build && firebase deploy --only hosting --project finance-96f46",
    "deploy:functions": "cd functions && npm run build && cd .. && firebase deploy --only functions --project finance-96f46",
    "deploy:all": "pnpm build && cd functions && npm run build && cd .. && firebase deploy --project finance-96f46"
  },
  "dependencies": {
    "@conference/firebase": "workspace:*",
    "@tanstack/react-query": "^5.91.0",
    "firebase": "^12.10.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "trust-ui-react": "^0.3.10"
  },
  "devDependencies": {
    "@conference/config": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "firebase-admin": "^13.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
